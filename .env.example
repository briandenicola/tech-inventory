# Tech Inventory — Production environment template
#
# Copy this file to `.env` next to docker-compose.yml on the deploy host, then
# fill in real values. NEVER commit the populated `.env`.
#
# Naming: ASP.NET Core binds env vars to config keys by replacing ":" with
# "__". `Auth__Entra__TenantId` here becomes the `Auth:Entra:TenantId` key
# the API reads at startup (src/TechInventory.Api/Program.cs).
#
# Placeholders prefixed `CHANGEME_` are *intentionally easy to grep* — if you
# see one in production logs, you forgot to replace it.

# ─────────────────────────────────────────────────────────────────────────────
# Image versioning
# ─────────────────────────────────────────────────────────────────────────────
# Image tag consumed by docker-compose.yml. Use `latest` for tip-of-main, or
# pin to a release tag (e.g. v0.1.0) for reproducible rollouts.
IMAGE_TAG=latest

# ─────────────────────────────────────────────────────────────────────────────
# Microsoft Entra ID (required)
# ─────────────────────────────────────────────────────────────────────────────
# Both values come from your Entra App registration → Overview blade:
#   TenantId = "Directory (tenant) ID"
#   ClientId = "Application (client) ID"
# Workforce tenant per D-001. Register the SPA redirect URI
# https://inventory.denicolafamily.com/auth/callback in the app's
# Authentication blade before first sign-in.
Auth__Entra__TenantId=CHANGEME_entra_tenant_guid
Auth__Entra__ClientId=CHANGEME_entra_client_guid

# Derived from the two GUIDs above. Authority is the v2.0 endpoint Entra
# tokens are issued from; Audiences__0/__1 are the two forms Entra stamps
# into the `aud` claim depending on the consent flow (api://<id> and bare).
Auth__Entra__Authority=https://login.microsoftonline.com/CHANGEME_entra_tenant_guid/v2.0
Auth__Entra__Audiences__0=api://CHANGEME_entra_client_guid
Auth__Entra__Audiences__1=CHANGEME_entra_client_guid

# ─────────────────────────────────────────────────────────────────────────────
# Local break-glass admin signing key (required)
# ─────────────────────────────────────────────────────────────────────────────
# HMAC-SHA256 signing key for local-issued JWTs. MUST be ≥ 32 bytes (256 bits).
# Generate with:
#     openssl rand -base64 48
# Rotation invalidates every outstanding local session immediately on API
# restart — see docs/deployment.md "Signing-key rotation" for the procedure.
Auth__Local__SigningKey=CHANGEME_run_openssl_rand_base64_48

# ─────────────────────────────────────────────────────────────────────────────
# Break-glass seed (FIRST BOOT ONLY — delete after first sign-in + rotation)
# ─────────────────────────────────────────────────────────────────────────────
# When SeedEnabled=true, the API ensures a local Admin row exists at startup
# with the username/password below and MustChangePasswordOnNextLogin=true.
# SeedAllowInProd=true is required in addition when ASPNETCORE_ENVIRONMENT
# is Production — defense-in-depth so a copied .env can't silently reseed a
# prod box. See docs/operations.md "Break-glass local admin" and the
# decommission steps in docs/deployment.md §5.
#
# NOTE: the code binds `SeedUsername` (not `SeedEmail`). Pick any short
# username — it's only ever typed at the local-sign-in fallback screen.
Auth__Local__SeedEnabled=false
Auth__Local__SeedAllowInProd=false
Auth__Local__SeedUsername=
Auth__Local__SeedPassword=CHANGEME_strong_temp_password_then_rotate

# ─────────────────────────────────────────────────────────────────────────────
# Same-origin CORS (required)
# ─────────────────────────────────────────────────────────────────────────────
# Public origin the SvelteKit PWA loads from. The API's CORS policy reads
# Cors:AllowedOrigins as a string[] (Program.cs:199). For Brian's home stack
# this is the NPM-fronted hostname; add additional entries (__1, __2, …) if
# you also serve from a LAN-only origin.
Cors__AllowedOrigins__0=https://inventory.denicolafamily.com

# ─────────────────────────────────────────────────────────────────────────────
# Observability (optional)
# ─────────────────────────────────────────────────────────────────────────────
# OpenTelemetry OTLP exporter endpoint. Leave commented to disable tracing
# (default). When set, the API also reads OpenTelemetry__OtlpEndpoint as the
# canonical config-key form; either env var works.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.lan:4317

# Serilog minimum level: Verbose | Debug | Information | Warning | Error | Fatal
Serilog__MinimumLevel__Default=Information
