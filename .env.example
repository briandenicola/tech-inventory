# Tech Inventory — Environment Variables (Example)
#
# Copy this file to `.env` and customize for your environment.
# NEVER commit the `.env` file — it carries real secrets.
#
# Key naming: ASP.NET Core binds env vars to config keys by replacing ":" with
# "__". `Auth__Entra__TenantId` in this file becomes the `Auth:Entra:TenantId`
# config key the API reads at startup (see `src/TechInventory.Api/Program.cs`).
#
# Every line tagged `# SECRET` is sensitive — treat it like a credential.
# Generate placeholder secrets with `openssl rand -base64 48` (or PowerShell
# equivalent) and store production values in your secret manager, not this file.

# ─────────────────────────────────────────────────────────────────────────────
# ASP.NET Core
# ─────────────────────────────────────────────────────────────────────────────
# Environment: Development | Staging | Production
# `docker-compose.prod.yml` forces this to `Production` regardless of .env;
# this default is the dev-friendly value used by the plain `docker-compose.yml`.
ASPNETCORE_ENVIRONMENT=Development

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
# SQLite connection string. The API container mounts the `techinv-data` volume
# at /data and writes to /data/techinv.db. EF Core migrations apply on startup
# (see Program.cs → `dbContext.Database.MigrateAsync()`).
ConnectionStrings__Default=Data Source=/data/techinv.db

# ─────────────────────────────────────────────────────────────────────────────
# Authentication — Microsoft Entra ID (primary identity provider)
# ─────────────────────────────────────────────────────────────────────────────
# v2.0 authority URL for token issuance + signing-key discovery. The tenant
# GUID in the path must match `Auth__Entra__TenantId` below.
Auth__Entra__Authority=https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000/v2.0

# Entra tenant ID (directory ID) — GUID from the App registration → Overview blade.
Auth__Entra__TenantId=00000000-0000-0000-0000-000000000000

# Entra application (client) ID — GUID from the App registration → Overview blade.
Auth__Entra__ClientId=00000000-0000-0000-0000-000000000000

# Accepted audiences. The API validates incoming tokens against this list.
# Convention: index 0 = `api://<client-id>`, index 1 = `<client-id>` bare.
# Both forms appear in Entra-issued tokens depending on consent flow.
Auth__Entra__Audiences__0=api://00000000-0000-0000-0000-000000000000
Auth__Entra__Audiences__1=00000000-0000-0000-0000-000000000000

# ─────────────────────────────────────────────────────────────────────────────
# Authentication — Local Break-Glass Admin (F025 v1b)
# ─────────────────────────────────────────────────────────────────────────────
# Fallback identity used when Entra is unreachable. See `docs/operations.md`
# (Break-glass local admin) for the full bootstrap + recovery flow.

# HMAC-SHA256 signing key for local-issued JWTs. MUST be ≥ 32 bytes.
# Generate with: openssl rand -base64 48
# Once set, NEVER rotate without invalidating every outstanding local session.
Auth__Local__SigningKey=<generate-with-openssl-rand-base64-48>  # SECRET

# Audience claim stamped onto local JWTs (and validated on incoming requests).
# Default matches `appsettings.json`; only change if you know why.
Auth__Local__Audience=techinventory-api

# Local access-token lifetime in minutes (default 480 = 8 hours).
# No refresh tokens in v1b — operator re-signs in after expiry.
Auth__Local__AccessTokenLifetimeMinutes=480

# ── Seed bootstrap (TEMPORARY — clear once you've signed in + rotated) ──────
# When SeedEnabled=true, the API ensures a local Admin row exists at startup
# with the username/password below and `MustChangePasswordOnNextLogin=true`.
# Disable (false or unset) after first successful sign-in + password rotation.
Auth__Local__SeedEnabled=false
Auth__Local__SeedUsername=
Auth__Local__SeedPassword=  # SECRET
# Defense-in-depth: must also be `true` for SeedEnabled to take effect in
# Production. Prevents an accidentally-copied .env from re-seeding prod hardware.
Auth__Local__SeedAllowInProd=false

# ── Argon2id password-hash parameters (OWASP 2025 baseline) ─────────────────
# Tune higher on capable hardware. Lowering these weakens password storage.
Auth__Local__Argon2__MemoryKib=19456
Auth__Local__Argon2__Iterations=2
Auth__Local__Argon2__Parallelism=1

# ─────────────────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────────────────
# OpenTelemetry OTLP exporter endpoint. The API reads this via the
# `OpenTelemetry:OtlpEndpoint` config key; the `OTEL_EXPORTER_OTLP_ENDPOINT`
# variable below is the canonical OTel SDK name and is preserved for tooling
# compatibility. Leave empty to disable tracing (default).
OTEL_EXPORTER_OTLP_ENDPOINT=
OpenTelemetry__OtlpEndpoint=

# Serilog minimum level: Verbose | Debug | Information | Warning | Error | Fatal
Serilog__MinimumLevel__Default=Information

# ─────────────────────────────────────────────────────────────────────────────
# Container image tag (production deploy)
# ─────────────────────────────────────────────────────────────────────────────
# Pin to a specific tag for reproducible rollouts; defaults to `latest`.
# Examples: `v1.2.3`, `54f8c6e` (short SHA), `latest` (main HEAD).
# Used by `docker-compose.prod.yml` only.
TECHINV_IMAGE_TAG=latest

# ─────────────────────────────────────────────────────────────────────────────
# Backups (Litestream sidecar — see `docker-compose.prod.yml` profile: backup)
# ─────────────────────────────────────────────────────────────────────────────
# Host path mounted into the litestream container as /backups. Continuous
# WAL-replica snapshots of /data/techinv.db land here under techinv/.
BACKUP_PATH=./backups

# Retention in days. Litestream prunes generations older than this on each
# snapshot cycle. Set to 0 to retain forever (not recommended).
BACKUP_RETENTION_DAYS=30

# Optional: replicate to an S3-compatible target in addition to the local
# file replica. Leave unset to keep backups on-host only. Example values:
#   s3://my-bucket/techinv
#   s3://my-bucket/techinv?endpoint=https://s3.us-west-002.backblazeb2.com&region=us-west-002
LITESTREAM_REPLICA_URL=

# Credentials for the S3-compatible target above. Only required when
# LITESTREAM_REPLICA_URL is set. Treat as secrets.
LITESTREAM_ACCESS_KEY_ID=       # SECRET
LITESTREAM_SECRET_ACCESS_KEY=   # SECRET
