# Tech Inventory — Environment Variables (Example)
# Copy this file to `.env` and customize for your local environment.
# NEVER commit the `.env` file — it may contain secrets.

# --- ASP.NET Core ---
# Environment: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Development

# --- Database ---
# SQLite connection string. In dev, the API writes to /data/techinv.db (Docker volume).
ConnectionStrings__Default=Data Source=/data/techinv.db

# --- Observability ---
# OpenTelemetry OTLP exporter endpoint (e.g., Seq or Jaeger). Leave empty in dev unless running local observability stack.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Serilog minimum level (Verbose, Debug, Information, Warning, Error, Fatal)
Serilog__MinimumLevel__Default=Information

# --- Authentication (Microsoft Entra ID) ---
# Azure AD tenant ID (leave as placeholder in dev; override in prod)
AzureAd__TenantId=your-tenant-id-here

# Azure AD client (application) ID
AzureAd__ClientId=your-client-id-here

# Azure AD client secret (NEVER commit this value)
AzureAd__ClientSecret=your-client-secret-here

# Allowed redirect URIs (comma-separated)
AzureAd__RedirectUri=http://localhost:3000/auth/callback

# --- Web (SvelteKit) ---
# Node environment
NODE_ENV=development

# Public API URL (used by browser clients)
PUBLIC_API_URL=http://localhost:8080/api/v1

# --- Backup / Restore ---
# Backup destination path (host path for scheduled backups)
BACKUP_PATH=/backups

# Backup retention days
BACKUP_RETENTION_DAYS=30
