#!/usr/bin/env sh
set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if ! command -v node >/dev/null 2>&1; then
  echo "Node.js is required to run the Tech Inventory pre-commit hook." >&2
  exit 1
fi

echo "✨ [1/2] Linting frontend..."
cd "$REPO_ROOT/src/TechInventory.Web"
pnpm run lint
cd "$REPO_ROOT"

echo ""
echo "🎭 [2/2] Scanning for auth tokens and secrets..."
node ./scripts/check-security.mjs --staged

echo ""
echo "✅ Pre-commit checks passed!"
